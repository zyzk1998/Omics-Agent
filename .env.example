# --- MCP 全网搜索 ---
# Tavily（高质量检索，优先于 ddgs）：https://tavily.com
# 将密钥写入本地 .env（勿提交含真实密钥的 .env）
TAVILY_API_KEY=

# --- NCBI（PubMed / Gene，E-utilities 与 Datasets API）---
# 密钥申请：https://www.ncbi.nlm.nih.gov/account/settings/
# E-utilities 使用 URL 参数 api_key=；Datasets v2 使用请求头 api-key
NCBI_API_KEY=
# 可选：E-utilities 建议填写联系邮箱
# NCBI_CONTACT_EMAIL=you@example.com

# Serper (Google): https://serper.dev
# SERPER_API_KEY=

# Azure Bing Search v7
# BING_SEARCH_API_KEY=
# BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# --- 存储守护：定时清理重型文件（保留 .csv/.md/.png/.json 等报告）---
# STORAGE_CLEANUP_DISABLED=0
# STORAGE_CLEANUP_INTERVAL_HOURS=12
# STORAGE_CLEANUP_MAX_DAYS=7
# STORAGE_CLEANUP_MAX_SIZE_GB=100
