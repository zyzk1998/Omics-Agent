# --- MCP 全网搜索 ---
# Tavily（高质量检索，优先于 ddgs）：https://tavily.com
# 将密钥写入本地 .env（勿提交含真实密钥的 .env）
TAVILY_API_KEY=

# --- NCBI（PubMed / Gene，E-utilities 与 Datasets API）---
# 密钥申请：https://www.ncbi.nlm.nih.gov/account/settings/
# E-utilities 使用 URL 参数 api_key=；Datasets v2 使用请求头 api-key
NCBI_API_KEY=
# 可选：E-utilities 建议填写联系邮箱
# NCBI_CONTACT_EMAIL=you@example.com

# Serper (Google): https://serper.dev
# SERPER_API_KEY=

# Azure Bing Search v7
# BING_SEARCH_API_KEY=
# BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# --- SiliconFlow：默认模型与聊天可选 model_name（须与前端 #modelSelect 的 value 一致）---
# SILICONFLOW_API_KEY=
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-R1
# 可选 model_name：deepseek-ai/DeepSeek-R1 | Pro/zai-org/GLM-5 | Pro/moonshotai/Kimi-K2.5 | Qwen/Qwen3.5-397B-A17B

# --- 存储守护：定时清理重型文件（保留 .csv/.md/.png/.json 等报告）---
# STORAGE_CLEANUP_DISABLED=0
# STORAGE_CLEANUP_INTERVAL_HOURS=12
# STORAGE_CLEANUP_MAX_DAYS=7
# STORAGE_CLEANUP_MAX_SIZE_GB=100

# --- BepiPred-3.0（技能广场 / bepipred3_prediction）---
# 默认：本地子进程调用 third_party/BepiPred-3.0（或 BEPIPRED3_ROOT），结果写入 RESULTS_DIR/bepipred3/
# Docker Compose 镜像默认 BEPIPRED3_PYTHON=/opt/bepipred3-venv/bin/python（见 services/api/Dockerfile）
# 本地：运行 bash scripts/bootstrap_bepipred_venv.sh 后指向 third_party/BepiPred-3.0/.venv/bin/python
# BEPIPRED3_ROOT=
# BEPIPRED3_PYTHON=
# docker compose build 与容器 entrypoint 补齐 venv 共用（CPU 默认）
# BEPIPRED_TORCH_INDEX=https://download.pytorch.org/whl/cpu
# BEPIPRED_TORCH_INDEX=https://download.pytorch.org/whl/cu121
# 关闭 API 容器启动时自动安装 BepiPred venv：BEPIPRED3_ENTRYPOINT_BOOTSTRAP=0
# BEPIPRED3_PYTHON_PROBE_TIMEOUT=120
# BEPIPRED3_SUBPROCESS_TIMEOUT=3600
# 与 FastAPI 静态挂载一致；未设置且无 /app 时工具会回退到仓库下 results/
# RESULTS_DIR=/app/results
# 前端若需绝对 URL 前缀（少数部署）
# PUBLIC_RESULTS_BASE_URL=
# 回退磐石远程 API 时设为 1，并可选覆盖端点
# BEPIPRED3_USE_REMOTE_API=0
# BEPIPRED3_PREDICT_URL=

# --- Docker Compose：对外端口（见 docker-compose.yml，勿在此重复定义除非改 compose）---
# Nginx 同时映射 80 与 8018 → 容器内 80（前端静态 + /api 反代至 api-server:8028）。
# 本地仅运行 python server.py 时默认监听 PORT（未设置则为 8018），与 Electron 默认 URL 常见写法一致。
# PORT=8018
