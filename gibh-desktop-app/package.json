{
  "name": "gibh-desktop-app",
  "version": "0.12.0",
  "description": "GIBH-AGENT-V2 Electron thin-client (V0.12)",
  "author": "GIBH Omics Agent",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "node scripts/prepare-pack-env.js && electron-builder --dir",
    "icons:win": "node scripts/gen-win-icon.js",
    "sync:download-page": "node scripts/write-download-release-meta.js",
    "prepare-pack-env": "node scripts/prepare-pack-env.js",
    "dist": "npm run prepare-pack-env && npm run icons:win && electron-builder && npm run sync:download-page",
    "dist:linux": "npm run prepare-pack-env && electron-builder --linux && npm run sync:download-page",
    "dist:win": "npm run prepare-pack-env && npm run icons:win && electron-builder --win --x64 && npm run sync:download-page",
    "dist:web": "npm run prepare-pack-env && npm run icons:win && electron-builder --linux --win portable && npm run sync:download-page",
    "publish:to-server": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/publish-omics-client-from-windows.ps1"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "ico-codec": "^1.0.0",
    "png-to-ico": "^2.1.8",
    "pngjs": "^6.0.0"
  },
  "build": {
    "appId": "com.gibh.agent.demo",
    "productName": "Omics Agent",
    "directories": {
      "output": "dist-out"
    },
    "icon": "app-icon.png",
    "files": [
      "main.js",
      "package.json",
      "app-icon.png",
      "offline.html",
      "node_modules/dotenv/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-pack.env",
        "to": "."
      }
    ],
    "win": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "icon": "build/icon.ico",
      "sign": null,
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Omics Agent",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "linux": {
      "artifactName": "${productName}-${version}.${ext}",
      "icon": "app-icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Science"
    }
  }
}
