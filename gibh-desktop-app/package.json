{
  "name": "gibh-desktop-app",
  "version": "0.13.1",
  "description": "GIBH-AGENT-V2 Electron thin-client (V0.13.1)",
  "author": "GIBH Omics Agent",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build-sidecar": "node scripts/build-sidecar.js",
    "pack": "node scripts/prepare-pack-env.js && electron-builder --dir",
    "sync:download-page": "node scripts/write-download-release-meta.js",
    "prepare-pack-env": "node scripts/prepare-pack-env.js",
    "predist": "npm run build-sidecar",
    "predist:linux": "npm run build-sidecar",
    "predist:win": "node scripts/predist-win-sidecar.js",
    "predist:web": "npm run build-sidecar && node scripts/predist-win-sidecar.js",
    "dist": "npm run prepare-pack-env && electron-builder && npm run sync:download-page",
    "dist:linux": "npm run prepare-pack-env && electron-builder --linux && npm run sync:download-page",
    "dist:win": "npm run prepare-pack-env && electron-builder --win --x64 && npm run sync:download-page",
    "dist:win:docker": "bash scripts/dist-win-via-docker.sh",
    "dist:web": "npm run prepare-pack-env && electron-builder --linux --win portable && npm run sync:download-page",
    "publish:to-server": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/publish-omics-client-from-windows.ps1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "ico-codec": "^1.0.0",
    "png-to-ico": "^2.1.8",
    "pngjs": "^6.0.0"
  },
  "build": {
    "appId": "com.gibh.agent.demo",
    "productName": "Omics Agent",
    "directories": {
      "output": "dist-out"
    },
    "icon": "build/icon.ico",
    "files": [
      "main.js",
      "package.json",
      "app-icon.png",
      "build/icon.ico",
      "offline.html",
      "node_modules/dotenv/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/universalify/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/argparse/**/*",
      "node_modules/sax/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-pack.env",
        "to": "."
      },
      {
        "from": "../services/nginx/html",
        "to": "bundled-web-ui",
        "filter": [
          "**/*",
          "!downloads/**",
          "!**/downloads/**",
          "!**/*.exe",
          "!**/*.AppImage",
          "!**/*.blockmap",
          "!**/*.tar.gz",
          "!**/*.dmg",
          "!**/*.zip",
          "!uploads/**",
          "!**/uploads/**",
          "!test_data/**",
          "!**/test_data/**",
          "!assets/demo/**",
          "!**/assets/demo/**"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}",
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "local_sidecar/dist",
          "to": "local_sidecar",
          "filter": ["local_sidecar.exe"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Omics Agent",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "linux": {
      "artifactName": "${productName}-${version}.${ext}",
      "icon": "app-icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Science",
      "extraResources": [
        {
          "from": "local_sidecar/dist",
          "to": "local_sidecar",
          "filter": ["local_sidecar"]
        }
      ]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://YOUR_SERVER_URL/downloads/"
      }
    ]
  }
}
