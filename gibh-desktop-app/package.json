{
  "name": "gibh-desktop-app",
  "version": "0.11.0",
  "description": "GIBH-AGENT-V2 Electron thin-client (V0.11)",
  "author": "GIBH Omics Agent",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "icons:win": "node scripts/gen-win-icon.js",
    "dist": "npm run icons:win && electron-builder",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.gibh.agent.demo",
    "productName": "Omics Agent",
    "directories": {
      "output": "dist-out"
    },
    "icon": "app-icon.png",
    "files": [
      "main.js",
      "package.json",
      "app-icon.png"
    ],
    "win": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Omics Agent",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    },
    "linux": {
      "artifactName": "${productName}-${version}.${ext}",
      "icon": "app-icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Science"
    }
  }
}
