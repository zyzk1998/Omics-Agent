{
  "name": "gibh-desktop-app",
  "version": "0.10.0",
  "description": "GIBH-AGENT-V2 Electron thin-client demo",
  "author": "GIBH Omics Agent",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gibh.agent.demo",
    "productName": "GIBH Agent Demo",
    "directories": {
      "output": "dist-out"
    },
    "icon": "../services/nginx/html/static/favicon.png",
    "files": [
      "main.js",
      "package.json"
    ],
    "artifactName": "GIBH-Agent-Demo-Setup-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GIBH Agent Demo"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Science"
    }
  }
}
